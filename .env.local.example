# UDealZone API Configuration
NEXT_PUBLIC_API_URL=https://api-v2.udealzone.com/api

# Google OAuth (Optional - for Google Sign-In)
# Get these from https://console.cloud.google.com
NEXT_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_google_web_client_id_here
# Backward-compatible fallback if you use Expo style variable naming
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_google_web_client_id_here

# Google Ads (AdSense)
# Use publisher client id like: ca-pub-xxxxxxxxxxxxxxxx
NEXT_PUBLIC_GOOGLE_ADS_CLIENT=ca-app-pub-9986429269406301/2580107471
NEXT_PUBLIC_GOOGLE_ADS_SLOT_HOME=ca-app-pub-9986429269406301/4611923189
NEXT_PUBLIC_GOOGLE_ADS_SLOT_LISTINGS=ca-app-pub-9986429269406301/4611923189
NEXT_PUBLIC_GOOGLE_ADS_SLOT_CATEGORY=ca-app-pub-9986429269406301/8520482255
NEXT_PUBLIC_GOOGLE_ADS_SLOT_BUYER=ca-app-pub-9986429269406301/6069510866
NEXT_PUBLIC_GOOGLE_ADS_SLOT_CITY=your-city-slot-id
NEXT_PUBLIC_GOOGLE_ADS_SLOT_SIDEBAR=your-sidebar-slot-id

# Environment
NEXT_PUBLIC_ENVIRONMENT=development
